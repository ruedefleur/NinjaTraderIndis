        [NinjaScriptProperty] 
        [XmlIgnore] 
        [Display(Name = "Bull Color", GroupName = "6. Fills & Text", Order = 0)]
        public System.Windows.Media.Brush BullBrush 
        { 
            get { return _bullBrush; } 
            set { _bullBrush = value; if (_bullBrush != null && _bullBrush.CanFreeze) _bullBrush.Freeze(); } 
        }
        [Browsable(false)] 
        public string BullBrushSer 
        { 
            get { return _bullBrush != null ? _bullBrush.ToString() : ""; } 
            set { 
                var b = (System.Windows.Media.Brush)new BrushConverter().ConvertFromString(value); 
                if (b != null && b.CanFreeze) b.Freeze(); 
                _bullBrush = b; 
            } 
        }

