        private SharpDX.Direct2D1.SolidColorBrush BrushFromWpf(SharpDX.Direct2D1.RenderTarget rt,
            System.Windows.Media.Brush wpfBrush, float alpha = 1.0f)
        {
            if (wpfBrush is System.Windows.Media.SolidColorBrush scb)
                return new SharpDX.Direct2D1.SolidColorBrush(rt,
                    new Color4(scb.Color.R / 255f, scb.Color.G / 255f, scb.Color.B / 255f, alpha));
            return new SharpDX.Direct2D1.SolidColorBrush(rt, new Color4(0.5f, 0.5f, 0.5f, alpha));
        }

        private SharpDX.Direct2D1.StrokeStyle StyleFromStroke(SharpDX.Direct2D1.RenderTarget rt, Stroke stroke)
        {
            var props = new StrokeStyleProperties();
            switch (stroke.DashStyleHelper)
            {
                case DashStyleHelper.Dash:       props.DashStyle = SharpDX.Direct2D1.DashStyle.Dash;       break;
                case DashStyleHelper.Dot:        props.DashStyle = SharpDX.Direct2D1.DashStyle.Dot;        break;
                case DashStyleHelper.DashDot:    props.DashStyle = SharpDX.Direct2D1.DashStyle.DashDot;    break;
                case DashStyleHelper.DashDotDot: props.DashStyle = SharpDX.Direct2D1.DashStyle.DashDotDot; break;
                default:                         props.DashStyle = SharpDX.Direct2D1.DashStyle.Solid;      break;
            }
            return new SharpDX.Direct2D1.StrokeStyle(rt.Factory, props);
        }

        private void BuildResources(SharpDX.Direct2D1.RenderTarget rt)
