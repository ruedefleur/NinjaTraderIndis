            _lastRT = rt;

            _bullDxBrush = BrushFromWpf(rt, BullBrush, 0.85f);
            _bearDxBrush = BrushFromWpf(rt, BearBrush, 0.85f);
            _textDxBrush = BrushFromWpf(rt, TextBrush, 1.00f);
            _wickDxBrush = BrushFromWpf(rt, WickStroke.Brush, 1.0f);
            _boxDxBrush  = BrushFromWpf(rt, BoxStroke.Brush, 0.5f);
            _cdoDxBrush  = BrushFromWpf(rt, CdoStroke.Brush, 0.8f);
            _pdoDxBrush  = BrushFromWpf(rt, PdoStroke.Brush, 0.8f);
            _pdhDxBrush  = BrushFromWpf(rt, PdhStroke.Brush, 0.8f);
            _pdlDxBrush  = BrushFromWpf(rt, PdlStroke.Brush, 0.8f);
            _pdcDxBrush  = BrushFromWpf(rt, PdcStroke.Brush, 0.8f);
            _asiaDxBrush = BrushFromWpf(rt, AsiaStroke.Brush, 0.8f);
            _lonDxBrush  = BrushFromWpf(rt, LondonStroke.Brush, 0.8f);
            _nyDxBrush   = BrushFromWpf(rt, NyStroke.Brush, 0.8f);

            _btnBgDxBrush   = new SharpDX.Direct2D1.SolidColorBrush(rt, new Color4(0.08f, 0.08f, 0.08f, 0.82f));
            _btnTextDxBrush = new SharpDX.Direct2D1.SolidColorBrush(rt, new Color4(0.9f, 0.9f, 0.9f, 1.0f));

            _boxDxStyle  = StyleFromStroke(rt, BoxStroke);
            _cdoDxStyle  = StyleFromStroke(rt, CdoStroke);
            _pdoDxStyle  = StyleFromStroke(rt, PdoStroke);
            _pdhDxStyle  = StyleFromStroke(rt, PdhStroke);
            _pdlDxStyle  = StyleFromStroke(rt, PdlStroke);
            _pdcDxStyle  = StyleFromStroke(rt, PdcStroke);
            _asiaDxStyle = StyleFromStroke(rt, AsiaStroke);
            _lonDxStyle  = StyleFromStroke(rt, LondonStroke);
            _nyDxStyle   = StyleFromStroke(rt, NyStroke);

            _dwFactory = new SharpDX.DirectWrite.Factory();

            _textFmt = new SharpDX.DirectWrite.TextFormat(_dwFactory, "Arial", 11f)
            {
                TextAlignment      = SharpDX.DirectWrite.TextAlignment.Leading,
                ParagraphAlignment = SharpDX.DirectWrite.ParagraphAlignment.Near,
                WordWrapping       = SharpDX.DirectWrite.WordWrapping.NoWrap
            };

            _timerTextFmt = new SharpDX.DirectWrite.TextFormat(_dwFactory, "Arial", 22f)
            {
                TextAlignment      = SharpDX.DirectWrite.TextAlignment.Center,
                ParagraphAlignment = SharpDX.DirectWrite.ParagraphAlignment.Near,
                WordWrapping       = SharpDX.DirectWrite.WordWrapping.NoWrap
            };

            _btnTextFmt = new SharpDX.DirectWrite.TextFormat(_dwFactory, "Arial", 11f)
            {
                TextAlignment      = SharpDX.DirectWrite.TextAlignment.Center,
                ParagraphAlignment = SharpDX.DirectWrite.ParagraphAlignment.Center,
                WordWrapping       = SharpDX.DirectWrite.WordWrapping.NoWrap
            };
        }

        // ── Render ────────────────────────────────────────────────────────────
        protected override void OnRender(ChartControl cc, ChartScale cs)
        {
            if (BarsArray.Length <= htf1Idx || htf1Idx < 0) return;

            var rt = RenderTarget;
            if (rt == null || rt.IsDisposed) return;
            if (!ReferenceEquals(rt, _lastRT)) BuildResources(rt);

            float rtW         = rt.Size.Width;
            float panelBottom = (float)cs.GetYByValue(cs.MinValue); 

            // ── Minimised: draw only the toggle pill in bottom-right ──────────
            if (_isMinimized)
            {
                float btnX = rtW - RightMarginPx - BtnW - BtnMX;
                float btnY = panelBottom - BtnH - BtnMY;
                _toggleBtnRect = new RectangleF(btnX, btnY, BtnW, BtnH);

                rt.FillRectangle(_toggleBtnRect, _btnBgDxBrush);
                rt.DrawRectangle(_toggleBtnRect, _boxDxBrush, 1f, _boxDxStyle);
                rt.DrawText("HTF  ▶", _btnTextFmt, _toggleBtnRect, _btnTextDxBrush);
                return;
            }

            // ── Expanded path: Dynamic scale and layout computation ───────────
            List<HTFBlock> activeBlocks = new List<HTFBlock>();

            if (htf1Idx > 0 && BarsArray.Length > htf1Idx)
            {
                int c = Math.Min(NumCandles1, BarsArray[htf1Idx].Count);
                if (c > 0) activeBlocks.Add(new HTFBlock { Idx = htf1Idx, Count = c });
            }
            if (ShowHTF2 && htf2Idx > 0 && BarsArray.Length > htf2Idx)
            {
                int c = Math.Min(NumCandles2, BarsArray[htf2Idx].Count);
                if (c > 0) activeBlocks.Add(new HTFBlock { Idx = htf2Idx, Count = c });
            }
            if (ShowHTF3 && htf3Idx > 0 && BarsArray.Length > htf3Idx)
            {
                int c = Math.Min(NumCandles3, BarsArray[htf3Idx].Count);
                if (c > 0) activeBlocks.Add(new HTFBlock { Idx = htf3Idx, Count = c });
            }
            if (ShowHTF4 && htf4Idx > 0 && BarsArray.Length > htf4Idx)
            {
                int c = Math.Min(NumCandles4, BarsArray[htf4Idx].Count);
                if (c > 0) activeBlocks.Add(new HTFBlock { Idx = htf4Idx, Count = c });
            }

            if (activeBlocks.Count == 0) return;

            // PRE-PASS: Layout blocks relative to 0, ensuring no overlapping text timers!
            float currentRelativeX = 0f;
            for (int i = 0; i < activeBlocks.Count; i++)
            {
                var block = activeBlocks[i];
                block.CandlesWidth = (block.Count * (CandleWidthPx + CandleGapPx)) - CandleGapPx;
                block.RelativeX    = currentRelativeX;

                float nextRelativeX = currentRelativeX + block.CandlesWidth + HTFBlockGapPx;

                // Check for timer overlap with the next group
                if (i < activeBlocks.Count - 1)
                {
                    var nextBlock = activeBlocks[i + 1];
                    float nextCandlesW = (nextBlock.Count * (CandleWidthPx + CandleGapPx)) - CandleGapPx;

                    // The timer is drawn over the LAST candle of a block.
                    // Its right edge is 40px from the center of that candle.
                    float timerN_Right = block.RelativeX + block.CandlesWidth - (CandleWidthPx / 2f) + 40f;
                    
                    // The next timer is drawn over the LAST candle of the NEXT block.
                    // Its left edge is 40px left from the center of that candle.
                    float timerNext_Left = nextRelativeX + nextCandlesW - (CandleWidthPx / 2f) - 40f;

                    // If the text blocks collide, dynamically push the next group further right!
                    if (timerN_Right + 15f > timerNext_Left) // 15px safety gap between text
                    {
                        nextRelativeX += (timerN_Right + 15f - timerNext_Left);
                    }
                }
                currentRelativeX = nextRelativeX;
            }

            // Calculate total required width encompassing all candles AND timer text overhangs
            var firstBlock = activeBlocks[0];
            float firstTimerLeft = firstBlock.RelativeX + firstBlock.CandlesWidth - (CandleWidthPx / 2f) - 40f;
            float leftOverhang   = firstTimerLeft < 0 ? -firstTimerLeft : 0f;

            var lastBlock = activeBlocks[activeBlocks.Count - 1];
            float lastTimerRight    = lastBlock.RelativeX + lastBlock.CandlesWidth - (CandleWidthPx / 2f) + 40f;
            float totalCandlesWidth = lastBlock.RelativeX + lastBlock.CandlesWidth;
            
            float maxRightEdge       = Math.Max(totalCandlesWidth, lastTimerRight);
            float totalRequiredWidth = maxRightEdge + leftOverhang;

            // Anchor exact drawing coordinates to the right side of the screen
            float rightEdgeBound = rtW - RightMarginPx;
            float startDrawingX  = rightEdgeBound - totalRequiredWidth + leftOverhang;

            float boxPadding = 15f;
            float boxStartX  = startDrawingX - leftOverhang - boxPadding;
            float boxW       = totalRequiredWidth + (boxPadding * 2);
            var   fullYBox   = new RectangleF(boxStartX, 0, boxW, panelBottom);

            // Draw box background/outline
            rt.DrawRectangle(fullYBox, _boxDxBrush, BoxStroke.Width, _boxDxStyle);

            float topY = 5f;

            // Draw each active HTF perfectly aligned
            foreach (var block in activeBlocks)
            {
                block.StartX = startDrawingX + block.RelativeX;
                
                RenderCandles(rt, cs, BarsArray[block.Idx], block.Count, block.StartX);
                DrawTimer(rt, BarsArray[block.Idx], block.StartX, topY, block.Count);
            }

            // Levels clipped to box
            rt.PushAxisAlignedClip(fullYBox, SharpDX.Direct2D1.AntialiasMode.PerPrimitive);

            var levels = new List<LevelLine>();

            if (ShowDailyLevels && BarsArray.Length > dailyIdx)
            {
                var dayBars = BarsArray[dailyIdx];
                if (dayBars.Count > 1)
                {
                    int prev = dayBars.Count - 2;
                    int curr = dayBars.Count - 1;
                    levels.Add(new LevelLine { Price = dayBars.GetOpen(prev),  Brush = _pdoDxBrush, Width = PdoStroke.Width, Style = _pdoDxStyle, Label = "PDO" });
                    levels.Add(new LevelLine { Price = dayBars.GetHigh(prev),  Brush = _pdhDxBrush, Width = PdhStroke.Width, Style = _pdhDxStyle, Label = "PDH" });
                    levels.Add(new LevelLine { Price = dayBars.GetLow(prev),   Brush = _pdlDxBrush, Width = PdlStroke.Width, Style = _pdlDxStyle, Label = "PDL" });
                    levels.Add(new LevelLine { Price = dayBars.GetClose(prev), Brush = _pdcDxBrush, Width = PdcStroke.Width, Style = _pdcDxStyle, Label = "PDC" });
                    levels.Add(new LevelLine { Price = dayBars.GetOpen(curr),  Brush = _cdoDxBrush, Width = CdoStroke.Width, Style = _cdoDxStyle, Label = "CDO" });
                }
            }

            if (ShowSessionLevels)
            {
                if (_curAsiaH != double.MinValue) levels.Add(new LevelLine { Price = _curAsiaH, Brush = _asiaDxBrush, Width = AsiaStroke.Width,   Style = _asiaDxStyle, Label = "Asia H" });
                if (_curAsiaL != double.MaxValue) levels.Add(new LevelLine { Price = _curAsiaL, Brush = _asiaDxBrush, Width = AsiaStroke.Width,   Style = _asiaDxStyle, Label = "Asia L" });
                if (_curLonH  != double.MinValue) levels.Add(new LevelLine { Price = _curLonH,  Brush = _lonDxBrush,  Width = LondonStroke.Width, Style = _lonDxStyle,  Label = "Lon H"  });
                if (_curLonL  != double.MaxValue) levels.Add(new LevelLine { Price = _curLonL,  Brush = _lonDxBrush,  Width = LondonStroke.Width, Style = _lonDxStyle,  Label = "Lon L"  });
                if (_curNyH   != double.MinValue) levels.Add(new LevelLine { Price = _curNyH,   Brush = _nyDxBrush,   Width = NyStroke.Width,     Style = _nyDxStyle,   Label = "NY H"   });
                if (_curNyL   != double.MaxValue) levels.Add(new LevelLine { Price = _curNyL,   Brush = _nyDxBrush,   Width = NyStroke.Width,     Style = _nyDxStyle,   Label = "NY L"   });
            }

            RenderLevelsWithCollisionHandling(rt, cs, levels, fullYBox.Left, fullYBox.Right);

            rt.PopAxisAlignedClip();

            // ── Toggle button: bottom-right corner of the box ─────────────────
            float bx = fullYBox.Right - BtnW - BtnMX;
            float by = panelBottom - BtnH - BtnMY;
            _toggleBtnRect = new RectangleF(bx, by, BtnW, BtnH);

            rt.FillRectangle(_toggleBtnRect, _btnBgDxBrush);
            rt.DrawRectangle(_toggleBtnRect, _boxDxBrush, 1f, _boxDxStyle);
            rt.DrawText("◀ Hide", _btnTextFmt, _toggleBtnRect, _btnTextDxBrush);
        }

        private void DrawTimer(SharpDX.Direct2D1.RenderTarget rt, Bars bars, float startX, float y, int count)
        {
            string timerStr = "--:--";
            if (State == State.Realtime)
            {
                DateTime htfCloseTime = bars.GetTime(bars.Count - 1);
                TimeSpan rem          = htfCloseTime - Core.Globals.Now;
                if (rem.TotalSeconds < 0) rem = TimeSpan.Zero;
                timerStr = string.Format("{0:00}:{1:00}", Math.Floor(rem.TotalMinutes), rem.Seconds);
            }

            // Centred over the newest (rightmost) candle of this block
            float lastCandleX = startX + (count - 1) * (CandleWidthPx + CandleGapPx);
            float centerX     = lastCandleX + CandleWidthPx * 0.5f;
            rt.DrawText(timerStr, _timerTextFmt, new RectangleF(centerX - 40f, y, 80f, 30f), _textDxBrush);
        }

        private void RenderCandles(SharpDX.Direct2D1.RenderTarget rt, ChartScale cs, Bars htfBars, int count, float startX)
        {
            int available = htfBars.Count;
            for (int i = count - 1; i >= 0; i--)
            {
                int    absIdx = available - 1 - i;
                double o      = htfBars.GetOpen(absIdx);
                double h      = htfBars.GetHigh(absIdx);
                double l      = htfBars.GetLow(absIdx);
                double c      = htfBars.GetClose(absIdx);
                bool   bull   = c >= o;

                int   slot = (count - 1) - i;
                float x    = startX + slot * (CandleWidthPx + CandleGapPx);
                float cx   = x + CandleWidthPx * 0.5f;

                float yO = (float)cs.GetYByValue(o);
                float yH = (float)cs.GetYByValue(h);
                float yL = (float)cs.GetYByValue(l);
                float yC = (float)cs.GetYByValue(c);

                float bodyTop = Math.Min(yO, yC);
                float bodyBot = Math.Max(yO, yC);
                float bodyH   = Math.Max(1.5f, bodyBot - bodyTop);

                if (yH < bodyTop) rt.DrawLine(new Vector2(cx, yH),      new Vector2(cx, bodyTop), _wickDxBrush, WickStroke.Width);
                if (yL > bodyBot) rt.DrawLine(new Vector2(cx, bodyBot), new Vector2(cx, yL),      _wickDxBrush, WickStroke.Width);

                var rect = new RectangleF(x, bodyTop, CandleWidthPx, bodyH);
                rt.FillRectangle(rect, bull ? _bullDxBrush : _bearDxBrush);
                rt.DrawRectangle(rect, _wickDxBrush, WickStroke.Width);
            }
        }

        private void RenderLevelsWithCollisionHandling(SharpDX.Direct2D1.RenderTarget rt, ChartScale cs,
            List<LevelLine> levels, float boxLeft, float boxRight)
        {
            var drawnRects = new List<RectangleF>();

            foreach (var line in levels)
            {
                float y = (float)cs.GetYByValue(line.Price);
                rt.DrawLine(new Vector2(boxLeft, y), new Vector2(boxRight, y), line.Brush, line.Width, line.Style);

                float textX = boxLeft + 4f;
                float textY = y - 16f;
                if (textY < 0) textY = y + 2f;

                const float shiftWidth = 50f;
                var collBox = new RectangleF(textX, textY, shiftWidth, 14f);

                bool overlap = true;
                int  safety  = 0;
                while (overlap && safety < 10)
                {
                    overlap = false;
                    foreach (var drawn in drawnRects)
                    {
                        if (collBox.Left < drawn.Right && collBox.Right > drawn.Left &&
                            collBox.Top  < drawn.Bottom && collBox.Bottom > drawn.Top)
                        {
                            collBox.Left  += shiftWidth + 5f;
                            collBox.Right  = collBox.Left + shiftWidth;
                            overlap = true;
                            break;
                        }
                    }
                    safety++;
                }

                drawnRects.Add(collBox);
                rt.DrawText(line.Label, _textFmt, new RectangleF(collBox.Left, collBox.Top, 200f, 14f), line.Brush);
            }
        }

