        protected override void OnStateChange()
        {
            if (State == State.SetDefaults)
            {
                Name                     = "HTF Candle Offset v2";
                Description              = "Draws up to 4 HTF candles dynamically scaled, local Daily/Session lines, and Timers";
                Calculate                = Calculate.OnPriceChange;
                IsOverlay                = true;
                DisplayInDataBox         = false;
                DrawOnPricePanel         = true;
                ScaleJustification       = ScaleJustification.Right;
                IsSuspendedWhileInactive = true;

                HTF1Type          = BarsPeriodType.Minute;
                HTF1Value         = 60;
                NumCandles1       = 5;

                ShowHTF2          = false;
                HTF2Type          = BarsPeriodType.Minute;
                HTF2Value         = 240;
                NumCandles2       = 3;

                ShowHTF3          = false;
                HTF3Type          = BarsPeriodType.Day;
                HTF3Value         = 1;
                NumCandles3       = 3;

                ShowHTF4          = false;
                HTF4Type          = BarsPeriodType.Week;
                HTF4Value         = 1;
                NumCandles4       = 3;

                CandleWidthPx     = 22;
                CandleGapPx       = 6;
                HTFBlockGapPx     = 30; // Minimum gap between the different HTF groups
                RightMarginPx     = 50;

                ShowDailyLevels   = true;
                ShowSessionLevels = true;

                AsiaStart         = new TimeSpan(18, 0, 0);
                AsiaEnd           = new TimeSpan(2, 0, 0);
                LondonStart       = new TimeSpan(3, 0, 0);
                LondonEnd         = new TimeSpan(11, 0, 0);
                NyStart           = new TimeSpan(8, 0, 0);
                NyEnd             = new TimeSpan(17, 0, 0);

                BullBrush         = System.Windows.Media.Brushes.DodgerBlue;
                BearBrush         = System.Windows.Media.Brushes.Red;
                TextBrush         = System.Windows.Media.Brushes.White;

                WickStroke        = new Stroke(System.Windows.Media.Brushes.Silver, DashStyleHelper.Solid, 1);
                BoxStroke         = new Stroke(System.Windows.Media.Brushes.Gray, DashStyleHelper.Dash, 1);
                CdoStroke         = new Stroke(System.Windows.Media.Brushes.Gold, DashStyleHelper.Solid, 2);
                PdoStroke         = new Stroke(System.Windows.Media.Brushes.DarkOrange, DashStyleHelper.Dash, 1);
                PdhStroke         = new Stroke(System.Windows.Media.Brushes.Salmon, DashStyleHelper.Dash, 1);
                PdlStroke         = new Stroke(System.Windows.Media.Brushes.LightGreen, DashStyleHelper.Dash, 1);
                PdcStroke         = new Stroke(System.Windows.Media.Brushes.Gray, DashStyleHelper.Dash, 1);
                AsiaStroke        = new Stroke(System.Windows.Media.Brushes.Cyan, DashStyleHelper.Dash, 1);
                LondonStroke      = new Stroke(System.Windows.Media.Brushes.Magenta, DashStyleHelper.Dash, 1);
                NyStroke          = new Stroke(System.Windows.Media.Brushes.Orange, DashStyleHelper.Dash, 1);
            }
            else if (State == State.Configure)
            {
                htf1Idx = 1;
                AddDataSeries(HTF1Type, HTF1Value);
                
                int nextIdx = 2;

                if (ShowHTF2)
                {
                    htf2Idx = nextIdx++;
                    AddDataSeries(HTF2Type, HTF2Value);
                }
                
                if (ShowHTF3)
                {
                    htf3Idx = nextIdx++;
                    AddDataSeries(HTF3Type, HTF3Value);
                }

                if (ShowHTF4)
                {
                    htf4Idx = nextIdx++;
                    AddDataSeries(HTF4Type, HTF4Value);
                }

                dailyIdx = nextIdx;
                AddDataSeries(BarsPeriodType.Day, 1);
            }
            else if (State == State.DataLoaded)
            {
                if (ChartControl != null)
                    ChartControl.MouseDown += OnChartMouseDown;
            }
            else if (State == State.Terminated)
            {
                if (ChartControl != null)
                    ChartControl.MouseDown -= OnChartMouseDown;
                FreeResources();
            }
        }

        // ── Mouse toggle ──────────────────────────────────────────────────────
        private void OnChartMouseDown(object sender, System.Windows.Input.MouseButtonEventArgs e)
        {
            if (e.ChangedButton != System.Windows.Input.MouseButton.Left) return;
            if (ChartControl == null || ChartControl.ChartPanels.Count == 0) return;

            var pos = e.GetPosition(ChartControl as System.Windows.IInputElement);
            var src  = System.Windows.PresentationSource.FromVisual(ChartControl);
            double dpiX = src?.CompositionTarget?.TransformToDevice.M11 ?? 1.0;
            double dpiY = src?.CompositionTarget?.TransformToDevice.M22 ?? 1.0;

            var panel = ChartControl.ChartPanels[0];
            float px = (float)(pos.X * dpiX) - (float)panel.X;
            float py = (float)(pos.Y * dpiY) - (float)panel.Y;

            if (px >= _toggleBtnRect.Left && px <= _toggleBtnRect.Right &&
                py >= _toggleBtnRect.Top  && py <= _toggleBtnRect.Bottom)
            {
                _isMinimized = !_isMinimized;
                e.Handled    = true;
                ForceRefresh();
            }
        }

        protected override void OnBarUpdate()
        {
            if (CurrentBar < 1 || BarsInProgress != 0 || !ShowSessionLevels)
                return;

            DateTime t0 = Time[0];
            DateTime t1 = Time[1];

            UpdateSession(t0, t1, AsiaStart,   AsiaEnd,   ref _curAsiaH, ref _curAsiaL);
            UpdateSession(t0, t1, LondonStart, LondonEnd, ref _curLonH,  ref _curLonL);
            UpdateSession(t0, t1, NyStart,     NyEnd,     ref _curNyH,   ref _curNyL);
        }

        private void UpdateSession(DateTime t0, DateTime t1, TimeSpan start, TimeSpan end, ref double high, ref double low)
        {
            if (IsInTime(t0, start, end))
            {
                if (!IsInTime(t1, start, end) || (t0 - t1).TotalHours > 12)
                {
                    high = High[0];
                    low  = Low[0];
                }
                else
                {
                    high = Math.Max(high, High[0]);
                    low  = Math.Min(low,  Low[0]);
                }
            }
        }

        private bool IsInTime(DateTime time, TimeSpan start, TimeSpan end)
        {
            TimeSpan tod = time.TimeOfDay;
            if (start < end) return tod >= start && tod < end;
            return tod >= start || tod < end;
        }

