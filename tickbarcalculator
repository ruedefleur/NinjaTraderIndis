		}

		public DynamicTickSizeOptimizer DynamicTickSizeOptimizer(ISeries<double> input, int targetBarsPerHour, int lookbackMinutes, bool showRawRecommendation)
		{
			if (cacheDynamicTickSizeOptimizer != null)
				for (int idx = 0; idx < cacheDynamicTickSizeOptimizer.Length; idx++)
