						return cacheDynamicTickSizeOptimizer[idx];
			return CacheIndicator<DynamicTickSizeOptimizer>(new DynamicTickSizeOptimizer(){ TargetBarsPerHour = targetBarsPerHour, LookbackMinutes = lookbackMinutes, ShowRawRecommendation = showRawRecommendation }, input, ref cacheDynamicTickSizeOptimizer);
